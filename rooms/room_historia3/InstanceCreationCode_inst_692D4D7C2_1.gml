
dialogo[0]="Letyel es un elfo arquero experimentado en la limpieza de dungeons.";
text=dialogo[0];
dialogo[1]="Dicen que nunca ha recibido una herida, que es invencible.";
dialogo[2]="Pero ahora se encuentra en problemas.";
dialogo[3]="Los goblins lo han rodeado, y no está seguro si \n le alcanzan las flechas para todos."
dialogo[4]="Tendrá que hacer los cálculos rápidamente..."
level=room_quiz3;
