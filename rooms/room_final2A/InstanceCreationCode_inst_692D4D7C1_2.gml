dialogo[0]="Al terminar, ¡Meladi obtiene una claridad matemática celestial!";
text=dialogo[0];
dialogo[1]="Gana el poder de... ¡la división!\n ¡Y lo usa para dividir al dios demoníaco!";
dialogo[2]="\"¡Perdóname la vida y te daré todo lo que tengo!\" rogó él.";
dialogo[3]="El plano infernal tiene a una nueva líder..."
dialogo[4]="...Y más matemáticas."
level=Room2;