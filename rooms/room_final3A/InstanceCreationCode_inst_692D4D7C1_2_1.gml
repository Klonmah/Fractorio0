
dialogo[0]="Al calcular, Letyel obtiene una claridad matemática celestial!";
text=dialogo[0];
dialogo[1]="Gana el poder de... ¡la suma!\n ¡Y lo usa para añadir tantas flechas como quiera!";
dialogo[2]="Múltiples flechas vuelan hacia los goblins, \n no tienen donde correr.";
dialogo[3]="El héroe saldrá de esta mazmorra como una leyenda..."
dialogo[4]="¡Letyel, el Infinito!"
level=Room2;