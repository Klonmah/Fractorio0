
dialogo[0]="Al reflexionar, Don Clamión obtiene una claridad matemática celestial!";
text=dialogo[0];
dialogo[1]="Gana el poder de... ¡la multiplicación!\n ¡Y lo usa para multiplicar una de sus ruedas!";
dialogo[2]="Un nuevo vendedor de llantas baratas parte\n hacia el horizonte... El mercado de llantas peligra.";
level=Room2;