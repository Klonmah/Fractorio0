show_debug_message(global.dificultad)
if global.dificultad=="fácil"
{
dialogo[0]="Un proceso ocupa  5/16 de la caché. Si un subproceso reclama 1/4 \n de ese espacio ocupado, \n¿qué fracción del total utiliza el subproceso?";
dialogo[1]="Para optimizar un bus de datos, se decide que solo 7/12 de su \ncapacidad será direccionable.\n ¿Cuál es el denominador de esta segmentación?";
dialogo[2]="Un ciclo de instrucción tarda 13/64 de ms. Si el overhead añade 1/32 de ms, \n¿cuál es el tiempo total?";
dialogo[3]="Un nodo de cómputo rinde a 6/7 de su capacidad. \n Si se reduce su frecuencia a la mitad (1/2),\n ¿cuál es su nuevo rendimiento?";
dialogo[4]="En la fracción 17/256 de tasa de colisión en una tabla hash,\n ¿cuál es el numerador?";
dialogo[5]="Elige la respuesta con un '1'!!!!!!";
dialogo[6]="Elige la respuesta con un '1'!!!!!!";
dialogo[7]="Elige la respuesta con un '1'!!!!!!!";
dialogo[8]="Elige la respuesta con un '1'!!!!!!!!";
dialogo[9]="Elige la respuesta con un '1'!!!!!!!!!";
}
if global.dificultad=="normal"
{
dialogo[0]="¿Cuál algoritmo es más eficiente si el A reduce un archivo a 3/11 de su tamaño\n y el B a 2/7?";
dialogo[1]="Un núcleo consume 3/10 de su energía en idle. Si al ejecutar un hilo \nel consumo aumenta en un factor de 5/3\n, ¿qué fracción de la energía total consume ahora?";
dialogo[2]="Ordena de menor a mayor uso de recursos: 4/15, 1/3 ,2/9";
dialogo[3]="Si un volumen tiene 12 de 12 sectores asignados a metadatos, \nsi liberamos 1/3 de la mitad del volumen \n¿qué fracción queda ocupada?";
dialogo[4]="¿Cuántos dieciseisavos (1/16) se requieren para representar \nun bloque que ocupa exactamente 3/4 del espacio?";
dialogo[5]="Elige la respuesta con un '1'!!!!!!";
dialogo[6]="Elige la respuesta con un '1'!!!!!!";
dialogo[7]="Elige la respuesta con un '1'!!!!!!!";
dialogo[8]="Elige la respuesta con un '1'!!!!!!!!";
dialogo[9]="Elige la respuesta con un '1'!!!!!!!!!";
}
if global.dificultad=="difícil"
{
dialogo[0]="El Algoritmo A tiene una probabilidad de fallo de 5/13 y \nel B es  3/2 veces más propenso al fallo. \n¿Cuál es más confiable?";
dialogo[1]="Una base de datos de 24TB\n tiene comprometidos 7/24 por redundancia y 5/12 por usuario. \n¿Qué fracción queda libre?";
dialogo[2]="¿Cuál de estas fracciones de carga equivale a saturación crítica (1 entero)?";
dialogo[3]="Si un buffer circular tiene ocupados 11/18 de sus punteros,\n Si cada microsegundo se vacía 1/9 de lo que queda,  \n¿qué fracción se vacía en el primer microsegundo?";
dialogo[4]="Compara el throughput de la Interfaz A (6/13) y la Interfaz B (18/39).";
dialogo[5]="Elige la respuesta con un '1'!!!!!!";
dialogo[6]="Elige la respuesta con un '1'!!!!!!";
dialogo[7]="Elige la respuesta con un '1'!!!!!!!";
dialogo[8]="Elige la respuesta con un '1'!!!!!!!!";
dialogo[9]="Elige la respuesta con un '1'!!!!!!!!!";
}
